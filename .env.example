# App environment (development/production)
NODE_ENV=development

# Frontend framework used in project
FRONTEND_APP=react

# Backend runtime used in project
BACKEND_RUNTIME=node

# Backend server port
PORT=5000

# Host port mapping for backend (Docker Compose)
BACKEND_PORT=5000

# Host port mapping for frontend (Docker Compose)
FRONTEND_PORT=3000

# Database host (use 'db' in Docker, RDS endpoint in production)
DB_HOST=

# Database port (default MySQL)
DB_PORT=

# Database name
DB_NAME=

# Database username
DB_USER=

# Database password
DB_PASS=

# JWT secret for authentication
JWT_SECRET=

# JWT token expiry time
JWT_EXPIRES_IN=1d

# API URL used by frontend
REACT_APP_API_URL=

# Internal backend URL for Docker networking
BACKEND_INTERNAL_URL=

# API base path for reverse proxy (Nginx)
API_BASE_PATH=/api

# Allowed origin for CORS
CORS_ORIGIN=

# AWS region for deployment
AWS_REGION=ap-south-1

# Logging level
LOG_LEVEL=info